generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Categoria {
  bicicletas
  accesorios
  partes
  herramientas
}

enum EstadoProducto {
  activo
  inactivo
}

enum EstadoVenta {
  pendiente
  completada
  cancelada
}

enum EstadoReparacion {
  pendiente
  en_proceso
  terminado
  entregado
}

enum EstadoPedido {
  pendiente
  completado
  cancelado
}

model User {
  id          Int      @id @default(autoincrement())
  nombre      String
  email       String   @unique
  password    String
  rol         String   @default("cliente")
  telefono    String?
  direccion   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  ventas      Venta[]
  citas       CitaReparacion[]
}

model Producto {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  precio      Float
  stock       Int      @default(0)
  stockMinimo Int      @default(5)
  categoria   Categoria
  marca       String?
  imagen      String?
  estado      EstadoProducto @default(activo)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  detallesVenta  DetalleVenta[]
  servicios      ServicioReparacion[]
  pedidoDetalles PedidoDetalle[]
}

model Venta {
  id          Int      @id @default(autoincrement())
  clienteId   Int
  total       Float
  estado      EstadoVenta @default(pendiente)
  fecha       DateTime @default(now())
  mpPaymentId String?
  mpMerchantOrderId String?
  mpPreferenceId String?
  
  cliente     User     @relation(fields: [clienteId], references: [id])
  detalles    DetalleVenta[]
}

model DetalleVenta {
  id         Int      @id @default(autoincrement())
  ventaId    Int
  productoId Int
  cantidad   Int
  precio     Float
  
  venta      Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto   Producto @relation(fields: [productoId], references: [id])
}

model CitaReparacion {
  id            Int      @id @default(autoincrement())
  clienteId     Int
  tipoBicicleta String
  descripcion   String
  fecha         DateTime
  hora          String
  estado        EstadoReparacion @default(pendiente)
  costoEstimado Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  cliente       User     @relation(fields: [clienteId], references: [id])
  servicios     ServicioReparacion[]
}

model Servicio {
  id          Int      @id @default(autoincrement())
  nombre      String
  costo       Float
  descripcion String?
  
  servicios   ServicioReparacion[]
}

model ServicioReparacion {
  id              Int     @id @default(autoincrement())
  citaId          Int
  productoId      Int?
  servicioId      Int?
  descripcion      String
  costo            Float
  
  cita             CitaReparacion @relation(fields: [citaId], references: [id], onDelete: Cascade)
  producto         Producto?       @relation(fields: [productoId], references: [id])
  servicio         Servicio?       @relation(fields: [servicioId], references: [id])
}

model Proveedor {
  id        Int      @id @default(autoincrement())
  nombre    String
  contacto  String?
  telefono  String?
  email     String?
  createdAt DateTime @default(now())
  
  pedidos   PedidoCompra[]
}

model PedidoCompra {
  id          Int      @id @default(autoincrement())
  proveedorId Int
  estado      EstadoPedido @default(pendiente)
  fecha       DateTime @default(now())
  total       Float?
  
  proveedor   Proveedor @relation(fields: [proveedorId], references: [id])
  detalles    PedidoDetalle[]
}

model PedidoDetalle {
  id            Int     @id @default(autoincrement())
  pedidoId      Int
  productoId    Int
  cantidad      Int
  costoUnitario Float
  
  pedido    PedidoCompra @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto Producto      @relation(fields: [productoId], references: [id])
}
